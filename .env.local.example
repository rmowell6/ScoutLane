# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
# Only NEXT_PUBLIC_* values are shipped to the browser — never prefix a secret with it.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...        # server-only; bypasses RLS

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...             # server-only

# Phase 2 (cron)
CRON_SECRET=

# Waitlist signup notification (AWS SES). All server-only — NEVER prefix with NEXT_PUBLIC_.
# When unset, signups are still captured; only the admin email notification is skipped (no-op).
# SES starts in the sandbox: verify the sender (or domain) AND the recipient address there.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                        # IAM user with ses:SendEmail
AWS_SECRET_ACCESS_KEY=
WAITLIST_NOTIFY_FROM=notify@scoutlane.app # a verified SES sender identity
WAITLIST_NOTIFY_TO=you@example.com        # admin inbox to notify on each signup
